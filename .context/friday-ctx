#!/bin/bash

# friday-ctx - War Room Context Management CLI
# Wrapper around Context7 and local context files for development assistance

set -e

WARROOM_ROOT="/home/eddy/Development/warroom"
CONTEXT7_CLI="/home/eddy/.npm-global/bin/c7"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

usage() {
    echo "friday-ctx - War Room Context Management"
    echo ""
    echo "USAGE:"
    echo "  friday-ctx find <query>           # Search local context files"
    echo "  friday-ctx library <lib> <query> # Get library documentation"  
    echo "  friday-ctx explore <path>        # Browse context hierarchy"
    echo "  friday-ctx auth                  # Show JWT authentication patterns"
    echo "  friday-ctx csrf                  # Show CSRF protection patterns"
    echo "  friday-ctx docker                # Show Docker rebuild patterns"
    echo "  friday-ctx api                   # Show API patterns"
    echo "  friday-ctx validate              # Validate context structure"
    echo "  friday-ctx init <path>           # Initialize context in directory"
    echo ""
    echo "EXAMPLES:"
    echo "  friday-ctx find 'JWT validation'"
    echo "  friday-ctx library fastapi 'JWT middleware'"
    echo "  friday-ctx explore backend"
    echo "  friday-ctx auth"
    echo "  friday-ctx docker"
}

# Search local context files
find_context() {
    local query="$1"
    if [ -z "$query" ]; then
        echo -e "${RED}Error: Query required${NC}"
        echo "Usage: friday-ctx find '<query>'"
        exit 1
    fi
    
    echo -e "${BLUE}Searching War Room context for: '$query'${NC}"
    echo ""
    
    # Search all context files
    find "$WARROOM_ROOT" -name ".context" -type d | while read -r context_dir; do
        if [ -f "$context_dir/index.md" ]; then
            local relative_path=${context_dir#$WARROOM_ROOT/}
            if grep -qi "$query" "$context_dir/index.md"; then
                echo -e "${GREEN}Found in: $relative_path${NC}"
                echo ""
                # Show matching lines with context
                grep -i -B2 -A2 --color=always "$query" "$context_dir/index.md" | head -20
                echo ""
                echo "────────────────────────────────────────────────────────────"
                echo ""
            fi
        fi
    done
}

# Get library documentation via Context7
library_docs() {
    local library="$1"
    local query="$2"
    
    if [ -z "$library" ] || [ -z "$query" ]; then
        echo -e "${RED}Error: Library and query required${NC}"
        echo "Usage: friday-ctx library <library> '<query>'"
        echo "Examples:"
        echo "  friday-ctx library fastapi 'JWT middleware'"
        echo "  friday-ctx library nextjs 'app router'"
        exit 1
    fi
    
    echo -e "${BLUE}Getting $library documentation for: '$query'${NC}"
    echo ""
    
    # Try Context7 API
    if command -v "$CONTEXT7_CLI" >/dev/null 2>&1; then
        echo -e "${YELLOW}Querying Context7 API...${NC}"
        "$CONTEXT7_CLI" search "$library" 2>/dev/null | head -5
        echo ""
        
        # Try to get specific documentation
        case "$library" in
            "fastapi")
                echo "Searching FastAPI documentation..."
                "$CONTEXT7_CLI" "/tiangolo/fastapi" "$query" 2>/dev/null || echo "Context7 API unavailable"
                ;;
            "nextjs"|"next")
                echo "Searching Next.js documentation..."
                "$CONTEXT7_CLI" "/vercel/next.js" "$query" 2>/dev/null || echo "Context7 API unavailable"
                ;;
            *)
                echo "Searching general documentation..."
                "$CONTEXT7_CLI" search "$library" 2>/dev/null || echo "Context7 API unavailable"
                ;;
        esac
    else
        echo -e "${YELLOW}Context7 CLI not available. Showing local patterns instead.${NC}"
        find_context "$query"
    fi
}

# Explore context hierarchy
explore_context() {
    local path="${1:-.}"
    local full_path="$WARROOM_ROOT/$path"
    
    if [ ! -d "$full_path" ]; then
        echo -e "${RED}Error: Path '$path' not found${NC}"
        exit 1
    fi
    
    echo -e "${BLUE}Exploring context in: $path${NC}"
    echo ""
    
    # Find all context directories under the path
    find "$full_path" -name ".context" -type d | while read -r context_dir; do
        local relative_path=${context_dir#$WARROOM_ROOT/}
        echo -e "${GREEN}📁 $relative_path${NC}"
        
        if [ -f "$context_dir/index.md" ]; then
            # Extract module name and description from YAML front matter
            local module_name=$(grep "module-name:" "$context_dir/index.md" | sed 's/module-name: *"\(.*\)"/\1/')
            local description=$(grep "description:" "$context_dir/index.md" | sed 's/description: *"\(.*\)"/\1/')
            
            echo "   Module: $module_name"
            echo "   Description: $description"
            echo ""
        fi
    done
}

# Show specific patterns
show_auth_patterns() {
    echo -e "${BLUE}JWT Authentication Patterns in War Room${NC}"
    echo ""
    
    if [ -f "$WARROOM_ROOT/backend/.context/index.md" ]; then
        echo -e "${GREEN}Backend JWT Flow:${NC}"
        grep -A 10 "JWT Authentication Flow" "$WARROOM_ROOT/backend/.context/index.md" | head -15
        echo ""
    fi
    
    if [ -f "$WARROOM_ROOT/frontend/.context/index.md" ]; then
        echo -e "${GREEN}Frontend Auth Context:${NC}"
        grep -A 10 "JWT Authentication Flow" "$WARROOM_ROOT/frontend/.context/index.md" | head -15
    fi
}

show_csrf_patterns() {
    echo -e "${BLUE}CSRF Protection Patterns${NC}"
    echo ""
    
    if [ -f "$WARROOM_ROOT/backend/.context/index.md" ]; then
        grep -A 8 "CSRF Protection" "$WARROOM_ROOT/backend/.context/index.md"
        echo ""
        
        echo -e "${GREEN}Allowed Origins:${NC}"
        grep -A 3 "allowed_origins:" "$WARROOM_ROOT/backend/.context/index.md"
    fi
}

show_docker_patterns() {
    echo -e "${BLUE}Docker Development Patterns${NC}"
    echo ""
    
    if [ -f "$WARROOM_ROOT/.context/index.md" ]; then
        echo -e "${GREEN}Container Architecture:${NC}"
        grep -A 10 "deployment:" "$WARROOM_ROOT/.context/index.md"
        echo ""
        
        echo -e "${GREEN}Rebuild Commands:${NC}"
        echo "# Full rebuild (recommended)"
        echo "docker compose up -d --build --remove-orphans"
        echo ""
        echo "# Backend only"
        echo "docker compose up -d --build backend --remove-orphans"
        echo ""
        echo "# Frontend only"  
        echo "docker compose up -d --build frontend --remove-orphans"
        echo ""
        echo "# Force rebuild without cache (if env vars changed)"
        echo "docker compose up -d --build --no-cache --remove-orphans"
    fi
}

show_api_patterns() {
    echo -e "${BLUE}API Development Patterns${NC}"
    echo ""
    
    if [ -f "$WARROOM_ROOT/backend/.context/index.md" ]; then
        echo -e "${GREEN}Route Handler Pattern:${NC}"
        grep -A 15 "Route Handler Pattern" "$WARROOM_ROOT/backend/.context/index.md"
        echo ""
        
        echo -e "${GREEN}Multi-Tenant Data Access:${NC}"
        grep -A 5 "Multi-Tenant Data Isolation" "$WARROOM_ROOT/backend/.context/index.md"
    fi
}

# Validate context structure
validate_context() {
    echo -e "${BLUE}Validating War Room context structure...${NC}"
    echo ""
    
    local errors=0
    
    # Check required context directories
    for dir in ".context" "backend/.context" "frontend/.context"; do
        if [ ! -d "$WARROOM_ROOT/$dir" ]; then
            echo -e "${RED}✗ Missing directory: $dir${NC}"
            errors=$((errors + 1))
        else
            echo -e "${GREEN}✓ Found directory: $dir${NC}"
        fi
    done
    
    # Check required index files
    for file in ".context/index.md" "backend/.context/index.md" "frontend/.context/index.md"; do
        if [ ! -f "$WARROOM_ROOT/$file" ]; then
            echo -e "${RED}✗ Missing file: $file${NC}"
            errors=$((errors + 1))
        else
            echo -e "${GREEN}✓ Found file: $file${NC}"
            
            # Validate YAML front matter
            if ! grep -q "^---$" "$WARROOM_ROOT/$file"; then
                echo -e "${YELLOW}  ⚠ Warning: No YAML front matter in $file${NC}"
                errors=$((errors + 1))
            fi
        fi
    done
    
    # Check diagram files
    for diagram in "auth-flow.mmd" "architecture.mmd" "docker-containers.mmd"; do
        if [ ! -f "$WARROOM_ROOT/.context/diagrams/$diagram" ]; then
            echo -e "${RED}✗ Missing diagram: .context/diagrams/$diagram${NC}"
            errors=$((errors + 1))
        else
            echo -e "${GREEN}✓ Found diagram: .context/diagrams/$diagram${NC}"
        fi
    done
    
    echo ""
    if [ $errors -eq 0 ]; then
        echo -e "${GREEN}✓ All context structure validations passed!${NC}"
    else
        echo -e "${RED}✗ Found $errors validation errors${NC}"
        exit 1
    fi
}

# Initialize context in a directory
init_context() {
    local path="${1:-.}"
    local full_path="$WARROOM_ROOT/$path"
    
    if [ ! -d "$full_path" ]; then
        echo -e "${RED}Error: Directory '$path' not found${NC}"
        exit 1
    fi
    
    local context_dir="$full_path/.context"
    
    if [ -d "$context_dir" ]; then
        echo -e "${YELLOW}Context directory already exists in $path${NC}"
        read -p "Overwrite? (y/N): " confirm
        if [ "$confirm" != "y" ]; then
            exit 0
        fi
    fi
    
    echo -e "${BLUE}Initializing context in: $path${NC}"
    mkdir -p "$context_dir"
    
    # Create basic index.md template
    cat > "$context_dir/index.md" << 'EOF'
---
module-name: "Module Name"
description: "Brief description of this module"
architecture:
  style: "Architecture style"
  components: []
patterns: []
---

# Module Context

## Overview

Brief overview of this module's purpose and functionality.

## Key Patterns

Document important patterns and practices used in this module.

## Common Issues

List common development issues and their solutions.
EOF
    
    echo -e "${GREEN}✓ Created $context_dir/index.md${NC}"
    echo ""
    echo "Next steps:"
    echo "1. Edit $context_dir/index.md with module-specific information"
    echo "2. Add patterns and documentation relevant to this module"
    echo "3. Run 'friday-ctx validate' to check structure"
}

# Main command dispatch
case "${1:-}" in
    "find")
        find_context "$2"
        ;;
    "library")
        library_docs "$2" "$3"
        ;;
    "explore")
        explore_context "$2"
        ;;
    "auth")
        show_auth_patterns
        ;;
    "csrf")
        show_csrf_patterns
        ;;
    "docker")
        show_docker_patterns
        ;;
    "api")
        show_api_patterns
        ;;
    "validate")
        validate_context
        ;;
    "init")
        init_context "$2"
        ;;
    "help"|"--help"|"-h"|"")
        usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        usage
        exit 1
        ;;
esac