# ============================================================
# War Room — Environment Variables
# Copy this file to .env and fill in the actual values.
# ============================================================

# ── Secrets (REQUIRED — app will NOT start without these) ────
# JWT signing key — generate with: openssl rand -hex 32
JWT_SECRET=

# PostgreSQL connection string for CRM database
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_URL=

# PostgreSQL connection string for LeadGen / knowledge database
# (often same DB as POSTGRES_URL but can be different)
LEADGEN_DB_URL=

# ── OpenClaw Integration ─────────────────────────────────────
OPENCLAW_AUTH_TOKEN=
OPENCLAW_DEVICE_ID=
OPENCLAW_DEVICE_PUBLIC_KEY=
OPENCLAW_DEVICE_PRIVATE_KEY=

# ── Service URLs ─────────────────────────────────────────────
# Brain 2 services (app backends)
KANBAN_API_URL=http://10.0.0.11:18794
TEAM_DASHBOARD_URL=http://10.0.0.11:18795
QDRANT_URL=http://10.0.0.11:6333
FASTEMBED_URL=http://10.0.0.11:11435

# Brain 1 services (pending migration)
OPENCLAW_WS_URL=ws://10.0.0.1:18789
OPENCLAW_API_URL=http://10.0.0.1:18789
MENTAL_LIBRARY_API_URL=http://10.0.0.1:8100
LEADGEN_BACKEND_URL=http://10.0.0.1:8200

# Public-facing URLs
BACKEND_URL=https://warroom.stuffnthings.io
FRONTEND_URL=http://localhost:3300

# ── Whisper (speech-to-text) ─────────────────────────────────
WHISPER_HOST=10.0.0.1
WHISPER_PORT=18796

# ── Frontend build args ─────────────────────────────────────
# WebSocket URL for the frontend (baked into JS bundle at build time)
NEXT_PUBLIC_WS_URL=ws://192.168.1.94:18789

# ── Paths ────────────────────────────────────────────────────
MENTAL_LIBRARY_DB=/data/mental-library/mental_library.db

# ── Admin Seed ───────────────────────────────────────────────
# Password for the initial admin user created by seed_admin.py
# REQUIRED when running seed_admin.py — must be at least 8 characters
ADMIN_PASSWORD=

