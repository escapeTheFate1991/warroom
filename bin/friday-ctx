#!/usr/bin/env python3
"""
Friday Context Management CLI
Semantic navigation and discovery for War Room context system
"""

import os
import sys
import json
import yaml
import argparse
import subprocess
from pathlib import Path
from typing import List, Dict, Any, Optional
import sqlite3
import hashlib
from datetime import datetime

# Add project root to path for imports
PROJECT_ROOT = Path(__file__).parent.parent
sys.path.insert(0, str(PROJECT_ROOT))

class ContextIndex:
    """Manages semantic indexing of context files"""
    
    def __init__(self, project_root: Path):
        self.project_root = project_root
        self.context_dir = project_root / ".context"
        self.index_db = self.context_dir / "index.db"
        self.embeddings_cache = self.context_dir / "embeddings.json"
        
    def init_db(self):
        """Initialize SQLite database for context index"""
        conn = sqlite3.connect(self.index_db)
        cursor = conn.cursor()
        
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS files (
                id INTEGER PRIMARY KEY,
                path TEXT UNIQUE,
                content_hash TEXT,
                last_updated TIMESTAMP,
                metadata TEXT
            )
        """)
        
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS chunks (
                id INTEGER PRIMARY KEY,
                file_id INTEGER,
                chunk_index INTEGER,
                content TEXT,
                embedding_vector TEXT,
                FOREIGN KEY (file_id) REFERENCES files (id)
            )
        """)
        
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS relationships (
                id INTEGER PRIMARY KEY,
                from_file TEXT,
                to_file TEXT,
                relationship_type TEXT,
                confidence REAL
            )
        """)
        
        conn.commit()
        conn.close()
    
    def scan_context_files(self) -> List[Path]:
        """Find all context files in the project"""
        context_files = []
        
        # Scan .context directory
        if self.context_dir.exists():
            context_files.extend(self.context_dir.glob("**/*.md"))
            context_files.extend(self.context_dir.glob("**/*.yaml"))
            context_files.extend(self.context_dir.glob("**/*.yml"))
        
        # Scan for .context directories throughout project
        for root, dirs, files in os.walk(self.project_root):
            if '.context' in dirs:
                context_path = Path(root) / '.context'
                context_files.extend(context_path.glob("**/*.md"))
                context_files.extend(context_path.glob("**/*.yaml"))
                context_files.extend(context_path.glob("**/*.yml"))
        
        return context_files
    
    def get_file_hash(self, file_path: Path) -> str:
        """Get MD5 hash of file content"""
        with open(file_path, 'rb') as f:
            return hashlib.md5(f.read()).hexdigest()
    
    def chunk_content(self, content: str, chunk_size: int = 512, overlap: int = 50) -> List[str]:
        """Split content into overlapping chunks"""
        chunks = []
        words = content.split()
        
        for i in range(0, len(words), chunk_size - overlap):
            chunk = " ".join(words[i:i + chunk_size])
            chunks.append(chunk)
            
            if i + chunk_size >= len(words):
                break
                
        return chunks
    
    def index_file(self, file_path: Path) -> bool:
        """Index a single context file"""
        try:
            content = file_path.read_text(encoding='utf-8')
            content_hash = self.get_file_hash(file_path)
            
            conn = sqlite3.connect(self.index_db)
            cursor = conn.cursor()
            
            # Check if file is already indexed and unchanged
            cursor.execute(
                "SELECT content_hash FROM files WHERE path = ?", 
                (str(file_path.relative_to(self.project_root)),)
            )
            result = cursor.fetchone()
            
            if result and result[0] == content_hash:
                conn.close()
                return False  # No changes
            
            # Extract metadata if YAML frontmatter exists
            metadata = {}
            if content.startswith('---'):
                try:
                    parts = content.split('---', 2)
                    if len(parts) >= 3:
                        metadata = yaml.safe_load(parts[1])
                        content = parts[2]
                except yaml.YAMLError:
                    pass
            
            # Insert or update file record
            cursor.execute("""
                INSERT OR REPLACE INTO files (path, content_hash, last_updated, metadata)
                VALUES (?, ?, ?, ?)
            """, (
                str(file_path.relative_to(self.project_root)),
                content_hash,
                datetime.now().isoformat(),
                json.dumps(metadata)
            ))
            
            file_id = cursor.lastrowid
            
            # Delete existing chunks for this file
            cursor.execute("DELETE FROM chunks WHERE file_id = ?", (file_id,))
            
            # Create and store chunks
            chunks = self.chunk_content(content)
            for i, chunk in enumerate(chunks):
                cursor.execute("""
                    INSERT INTO chunks (file_id, chunk_index, content, embedding_vector)
                    VALUES (?, ?, ?, ?)
                """, (file_id, i, chunk, ""))  # Embedding computation placeholder
            
            conn.commit()
            conn.close()
            return True
            
        except Exception as e:
            print(f"Error indexing {file_path}: {e}")
            return False
    
    def build_index(self):
        """Build or rebuild the complete context index"""
        self.init_db()
        
        files = self.scan_context_files()
        print(f"Found {len(files)} context files to index...")
        
        updated = 0
        for file_path in files:
            if self.index_file(file_path):
                updated += 1
                print(f"Indexed: {file_path.relative_to(self.project_root)}")
        
        print(f"Index complete. {updated} files updated.")
    
    def search(self, query: str, limit: int = 5) -> List[Dict[str, Any]]:
        """Search context using simple text matching"""
        conn = sqlite3.connect(self.index_db)
        cursor = conn.cursor()
        
        # Simple text search across content
        cursor.execute("""
            SELECT f.path, f.metadata, c.content, 
                   (CASE 
                       WHEN c.content LIKE ? THEN 3
                       WHEN c.content LIKE ? THEN 2
                       WHEN c.content LIKE ? THEN 1
                       ELSE 0
                   END) as relevance
            FROM files f
            JOIN chunks c ON f.id = c.file_id
            WHERE c.content LIKE ?
            ORDER BY relevance DESC, f.last_updated DESC
            LIMIT ?
        """, (
            f"%{query}%",  # Exact phrase match (highest relevance)
            f"%{query.split()[0] if query.split() else query}%",  # First word match
            f"%{' '.join(query.split()[:2]) if len(query.split()) > 1 else query}%",  # First two words
            f"%{query}%",  # Any match
            limit
        ))
        
        results = []
        for row in cursor.fetchall():
            path, metadata_json, content, relevance = row
            metadata = json.loads(metadata_json) if metadata_json else {}
            
            results.append({
                'path': path,
                'metadata': metadata,
                'content_preview': content[:200] + "..." if len(content) > 200 else content,
                'relevance': relevance
            })
        
        conn.close()
        return results

class ContextCLI:
    """Friday Context Management CLI Interface"""
    
    def __init__(self):
        self.project_root = Path.cwd()
        while not (self.project_root / ".context").exists() and self.project_root != self.project_root.parent:
            self.project_root = self.project_root.parent
        
        self.index = ContextIndex(self.project_root)
    
    def find(self, query: str, limit: int = 5):
        """Find context by natural language query"""
        print(f"🔍 Searching for: {query}")
        print("-" * 50)
        
        results = self.index.search(query, limit)
        
        if not results:
            print("No results found.")
            return
        
        for i, result in enumerate(results, 1):
            print(f"{i}. {result['path']}")
            print(f"   {result['content_preview']}")
            if result['metadata']:
                print(f"   Metadata: {result['metadata']}")
            print()
    
    def explore(self, path: str = None):
        """Explore context hierarchy"""
        if path:
            target = Path(path)
        else:
            target = self.project_root / ".context"
        
        print(f"📁 Exploring: {target}")
        print("-" * 50)
        
        if not target.exists():
            print(f"Path does not exist: {target}")
            return
        
        # List context files with metadata
        for item in sorted(target.rglob("*")):
            if item.is_file() and item.suffix in ['.md', '.yaml', '.yml']:
                rel_path = item.relative_to(self.project_root)
                print(f"📄 {rel_path}")
                
                # Try to read metadata
                try:
                    content = item.read_text(encoding='utf-8')
                    if content.startswith('---'):
                        parts = content.split('---', 2)
                        if len(parts) >= 3:
                            metadata = yaml.safe_load(parts[1])
                            if 'description' in metadata:
                                print(f"   {metadata['description']}")
                except:
                    pass
                print()
    
    def related(self, file_path: str):
        """Find related context files"""
        print(f"🔗 Finding files related to: {file_path}")
        print("-" * 50)
        
        # For now, simple implementation based on common keywords
        target_file = Path(file_path)
        if not target_file.exists():
            print(f"File does not exist: {file_path}")
            return
        
        try:
            content = target_file.read_text(encoding='utf-8').lower()
            keywords = set(content.split())
            
            context_files = self.index.scan_context_files()
            related = []
            
            for context_file in context_files:
                if context_file == target_file:
                    continue
                
                try:
                    other_content = context_file.read_text(encoding='utf-8').lower()
                    other_keywords = set(other_content.split())
                    
                    common_keywords = keywords.intersection(other_keywords)
                    if len(common_keywords) > 10:  # Threshold for relatedness
                        score = len(common_keywords) / len(keywords.union(other_keywords))
                        related.append((context_file, score, len(common_keywords)))
                
                except:
                    continue
            
            # Sort by relatedness score
            related.sort(key=lambda x: x[1], reverse=True)
            
            for context_file, score, common_count in related[:5]:
                rel_path = context_file.relative_to(self.project_root)
                print(f"📄 {rel_path} (score: {score:.2f}, common: {common_count})")
        
        except Exception as e:
            print(f"Error finding related files: {e}")
    
    def status(self):
        """Show context index status"""
        print("📊 Context Index Status")
        print("-" * 50)
        
        if not self.index.index_db.exists():
            print("❌ Index not built. Run 'friday-ctx index' first.")
            return
        
        conn = sqlite3.connect(self.index.index_db)
        cursor = conn.cursor()
        
        cursor.execute("SELECT COUNT(*) FROM files")
        file_count = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM chunks")
        chunk_count = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM relationships")
        relationship_count = cursor.fetchone()[0]
        
        cursor.execute("SELECT MAX(last_updated) FROM files")
        last_updated = cursor.fetchone()[0]
        
        conn.close()
        
        print(f"📄 Indexed files: {file_count}")
        print(f"📦 Content chunks: {chunk_count}")
        print(f"🔗 Relationships: {relationship_count}")
        print(f"🕒 Last updated: {last_updated or 'Never'}")
        
        context_files = self.index.scan_context_files()
        print(f"📁 Available files: {len(context_files)}")
    
    def index_rebuild(self):
        """Rebuild the context index"""
        print("🔄 Building context index...")
        self.index.build_index()

def main():
    """Main CLI entry point"""
    parser = argparse.ArgumentParser(
        description="Friday Context Management CLI",
        prog="friday-ctx"
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Available commands')
    
    # Find command
    find_parser = subparsers.add_parser('find', help='Find context by query')
    find_parser.add_argument('query', help='Search query')
    find_parser.add_argument('-l', '--limit', type=int, default=5, help='Maximum results')
    
    # Explore command
    explore_parser = subparsers.add_parser('explore', help='Explore context hierarchy')
    explore_parser.add_argument('path', nargs='?', help='Path to explore (default: .context)')
    
    # Related command
    related_parser = subparsers.add_parser('related', help='Find related context files')
    related_parser.add_argument('file', help='File to find relations for')
    
    # Status command
    status_parser = subparsers.add_parser('status', help='Show context index status')
    
    # Index command
    index_parser = subparsers.add_parser('index', help='Build/rebuild context index')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return
    
    cli = ContextCLI()
    
    try:
        if args.command == 'find':
            cli.find(args.query, args.limit)
        elif args.command == 'explore':
            cli.explore(args.path)
        elif args.command == 'related':
            cli.related(args.file)
        elif args.command == 'status':
            cli.status()
        elif args.command == 'index':
            cli.index_rebuild()
    except KeyboardInterrupt:
        print("\nOperation cancelled.")
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()